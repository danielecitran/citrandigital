{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@/*": ["citrandigital/*"]
    }
  },
  "include": [
    "citrandigital/**/*.ts",
    "citrandigital/**/*.tsx",
    "citrandigital/**/*.mts",
    "citrandigital/next-env.d.ts",
    "citrandigital/.next/types/**/*.ts"
  ],
  "exclude": ["citrandigital/node_modules", "citrandigital/.next"]
}
